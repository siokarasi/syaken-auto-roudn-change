{
  "manifest_version": 3,
  "name": "車検ラウンド変更自動化",
  "version": "1.0.0",
  "description": "車検予約システムのラウンド変更を監視して自動化します。",
  "permissions": ["storage", "tabs", "webNavigation"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://ams-yoyaku.jp/*", "*://*.ams-yoyaku.jp/*"],
      "js": ["content_isolated.js"],
      "all_frames": true,
      "world": "ISOLATED"
    },
    {
      "matches": ["*://ams-yoyaku.jp/*", "*://*.ams-yoyaku.jp/*"],
      "js": ["content_main.js"],
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}
